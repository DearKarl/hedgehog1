{
  "name": "hedgehog1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hedgehog One v0.1a deterministic Diagram IR to SVG compiler.",
  "bin": {
    "hedgehog1": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format:check": "prettier . --check",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm format:check"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.7",
    "eslint": "^9.30.1",
    "fast-check": "^4.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.7.0"
}
