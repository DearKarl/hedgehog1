{
  "$id": "https://github.com/DearKarl/hedgehog1/schemas/diagram-ir.v0.1a.schema.json",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "irVersion": {
      "const": "0.1a",
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$",
      "type": "string"
    },
    "title": {
      "minLength": 1,
      "type": "string"
    },
    "kind": {
      "const": "dataflow",
      "type": "string"
    },
    "direction": {
      "const": "left-to-right",
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "properties": {
          "id": {
            "minLength": 1,
            "pattern": "^[A-Za-z][A-Za-z0-9_-]*$",
            "type": "string"
          },
          "label": {
            "minLength": 1,
            "type": "string"
          },
          "role": {
            "anyOf": [
              {
                "const": "source",
                "type": "string"
              },
              {
                "const": "transform",
                "type": "string"
              },
              {
                "const": "model",
                "type": "string"
              },
              {
                "const": "metric",
                "type": "string"
              },
              {
                "const": "output",
                "type": "string"
              }
            ]
          }
        },
        "required": ["id", "label", "role"]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "properties": {
          "id": {
            "minLength": 1,
            "pattern": "^[A-Za-z][A-Za-z0-9_-]*$",
            "type": "string"
          },
          "from": {
            "minLength": 1,
            "type": "string"
          },
          "to": {
            "minLength": 1,
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "evidenceRef": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": ["id", "from", "to"]
      }
    },
    "metadata": {
      "type": "object",
      "patternProperties": {
        "^(.*)$": {}
      }
    }
  },
  "required": ["irVersion", "id", "title", "kind", "direction", "nodes", "edges", "metadata"]
}
